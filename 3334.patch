From ae50fb8df8ae12a811603512d6748c3ff069786e Mon Sep 17 00:00:00 2001
From: Faizan Zafar <faizan.zafar01@student.csulb.edu>
Date: Sun, 25 Aug 2024 16:28:34 -0700
Subject: [PATCH 2/3] refactor: normalize chapter titles for finding chapter
 hrefs

---
 client/components/readers/EpubReader.vue | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/client/components/readers/EpubReader.vue b/client/components/readers/EpubReader.vue
index 14f9c6065..c141812de 100644
--- a/client/components/readers/EpubReader.vue
+++ b/client/components/readers/EpubReader.vue
@@ -470,9 +470,12 @@ export default {
       return chapter.title || audioBookChapters[audioBookChapters.length - 1].title
     },
     findChapterHref(title) {
+      const normalizeString = (str) => {
+        return str.replace(/[^a-zA-Z0-9]/g, '').toLowerCase()
+      }
       const findInToc = (items) => {
         for (let item of items) {
-          if (item.label.trim() === title) return item.href
+          if (normalizeString(item.label) === normalizeString(title)) return item.href
           if (item.subitems) {
             const result = findInToc(item.subitems)
             if (result) return result

